# Airtable
AIRTABLE_API_KEY=pat_xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appZoN6xBB9mDv8h4

