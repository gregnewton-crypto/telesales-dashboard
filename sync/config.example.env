# Google Sheets
GOOGLE_SHEET_ID=your_google_spreadsheet_id_from_the_url

# Paste the full service account JSON on one line, or use a file path in local runs
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: override which tables/sheets to sync (JSON array)
# SYNC_TABLES_JSON=[{"name":"📊 Weekly KPIs v2","sheet":"Weekly KPIs"},{"name":"💷 Spend Tracker","sheet":"Spend Tracker"},{"name":"🔍 Pause Reason Analysis","sheet":"Pause Reasons"}]
